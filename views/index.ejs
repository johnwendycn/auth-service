<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= serviceName %> — Authentication API Documentation</title>
  <meta name="description" content="Enterprise-grade authentication microservice with RS256 JWT, refresh token rotation, and JWKS distribution. Complete API documentation for developers." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: #f9fafb;
      color: #111827;
      line-height: 1.5;
    }

    /* Top Bar */
    .topbar {
      background: #ffffff;
      border-bottom: 1px solid #e5e7eb;
      position: sticky;
      top: 0;
      z-index: 100;
      backdrop-filter: blur(8px);
      background: rgba(255,255,255,0.95);
    }

    .container {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    .topbar-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 64px;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-weight: 700;
      font-size: 1.25rem;
      text-decoration: none;
      color: #111827;
    }

    .brand-mark {
      background: #0f172a;
      color: white;
      width: 28px;
      height: 28px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 8px;
      font-weight: 700;
    }

    .topnav {
      display: flex;
      gap: 1.5rem;
    }

    .topnav a {
      text-decoration: none;
      color: #4b5563;
      font-weight: 500;
      font-size: 0.875rem;
      transition: color 0.2s;
    }

    .topnav a:hover {
      color: #0f172a;
    }

    .pill {
      background: #eef2ff;
      padding: 0.25rem 0.75rem;
      border-radius: 999px;
      font-family: monospace;
      font-size: 0.75rem;
    }

    /* Hero */
    .hero {
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
      color: white;
      padding: 4rem 0;
      border-bottom: 1px solid #334155;
    }

    .hero-inner {
      max-width: 900px;
    }

    .eyebrow {
      text-transform: uppercase;
      font-size: 0.75rem;
      letter-spacing: 0.1em;
      color: #94a3b8;
      margin-bottom: 1rem;
      display: inline-block;
    }

    .hero h1 {
      font-size: 3rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 1rem;
      line-height: 1.2;
    }

    .lede {
      font-size: 1.25rem;
      color: #cbd5e1;
      margin-bottom: 2rem;
      max-width: 600px;
    }

    .hero-actions {
      display: flex;
      gap: 1rem;
      margin-bottom: 2rem;
    }

    .btn {
      display: inline-flex;
      padding: 0.625rem 1.25rem;
      border-radius: 8px;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.2s;
    }

    .btn-primary {
      background: #3b82f6;
      color: white;
    }

    .btn-primary:hover {
      background: #2563eb;
    }

    .btn-ghost {
      background: transparent;
      color: white;
      border: 1px solid #475569;
    }

    .btn-ghost:hover {
      background: rgba(255,255,255,0.05);
      border-color: #64748b;
    }

    .hero-meta {
      display: flex;
      gap: 2rem;
      flex-wrap: wrap;
      font-size: 0.875rem;
      color: #94a3b8;
    }

    .hero-meta strong {
      color: white;
      font-weight: 600;
      display: block;
      font-size: 0.75rem;
      margin-bottom: 0.25rem;
    }

    /* Main content */
    .section {
      padding: 3rem 0;
      border-bottom: 1px solid #e5e7eb;
    }

    h2 {
      font-size: 1.875rem;
      font-weight: 600;
      letter-spacing: -0.01em;
      margin-bottom: 1rem;
      color: #0f172a;
    }

    h3 {
      font-size: 1.25rem;
      font-weight: 600;
      margin: 1.5rem 0 1rem;
      color: #1e293b;
    }

    .group-title {
      margin-top: 2rem;
      padding-bottom: 0.5rem;
      border-bottom: 2px solid #e2e8f0;
    }

    .muted {
      color: #6b7280;
      margin-bottom: 1.5rem;
    }

    .small {
      font-size: 0.875rem;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
      margin: 1.5rem 0;
    }

    .card {
      background: white;
      border-radius: 16px;
      padding: 1.5rem;
      border: 1px solid #e5e7eb;
      box-shadow: 0 1px 2px rgba(0,0,0,0.05);
    }

    .card h3 {
      margin-top: 0;
      margin-bottom: 0.75rem;
    }

    /* Endpoint styling */
    .endpoint {
      background: white;
      border-radius: 12px;
      margin: 1.5rem 0;
      border: 1px solid #e5e7eb;
      overflow: hidden;
    }

    .endpoint-header {
      padding: 1rem 1.5rem;
      background: #f8fafc;
      border-bottom: 1px solid #e5e7eb;
      display: flex;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .method {
      font-weight: 700;
      font-size: 0.75rem;
      padding: 0.25rem 0.75rem;
      border-radius: 20px;
      background: #eef2ff;
      color: #1e40af;
      font-family: monospace;
    }

    .method.post { background: #dcfce7; color: #166534; }
    .method.get { background: #dbeafe; color: #1e40af; }
    .method.put { background: #fed7aa; color: #9a3412; }
    .method.delete { background: #fee2e2; color: #991b1b; }

    .path {
      font-family: 'JetBrains Mono', monospace;
      font-weight: 500;
      color: #0f172a;
    }

    .endpoint-body {
      padding: 1.5rem;
    }

    .param-table {
      width: 100%;
      border-collapse: collapse;
      margin: 1rem 0;
      font-size: 0.875rem;
    }

    .param-table th, .param-table td {
      padding: 0.75rem;
      text-align: left;
      border-bottom: 1px solid #e5e7eb;
    }

    .param-table th {
      background: #f9fafb;
      font-weight: 600;
      color: #374151;
    }

    code {
      background: #f1f5f9;
      padding: 0.2rem 0.4rem;
      border-radius: 6px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.85em;
    }

    pre {
      background: #0f172a;
      color: #e2e8f0;
      padding: 1rem;
      border-radius: 12px;
      overflow-x: auto;
      margin: 1rem 0;
      font-size: 0.8rem;
    }

    pre code {
      background: none;
      padding: 0;
      color: inherit;
    }

    .note {
      background: #fffbeb;
      border-left: 3px solid #f59e0b;
      padding: 1rem;
      border-radius: 8px;
      margin: 1rem 0;
    }

    .tabs {
      display: flex;
      gap: 0.5rem;
      border-bottom: 1px solid #e5e7eb;
      margin-bottom: 1rem;
    }

    .tab {
      background: none;
      border: none;
      padding: 0.5rem 1rem;
      font-family: inherit;
      font-weight: 500;
      cursor: pointer;
      color: #6b7280;
      border-radius: 8px 8px 0 0;
    }

    .tab.active {
      color: #3b82f6;
      border-bottom: 2px solid #3b82f6;
    }

    .tab-panel {
      display: none;
    }

    .tab-panel.active {
      display: block;
    }

    .footer {
      background: white;
      border-top: 1px solid #e5e7eb;
      padding: 2rem 0;
      margin-top: 2rem;
    }

    .footer-inner {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .footer-links {
      display: flex;
      gap: 1.5rem;
    }

    .footer-links a {
