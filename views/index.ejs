<body>
  <header class="topbar">
    <div class="container topbar-inner">
      <a href="#" class="brand">
        <span class="brand-mark">⚡</span>
        <span class="brand-text"><%= serviceName %></span>
      </a>
      <nav class="topnav">
        <a href="#overview">Overview</a>
        <a href="#endpoints">Endpoints</a>
        <a href="#integration">Integration</a>
        <a href="#security">Security</a>
        <a href="/health" class="pill">/health</a>
      </nav>
    </div>
  </header>

  <section class="hero">
    <div class="container hero-inner">
      <span class="eyebrow">Enterprise Authentication Service</span>
      <h1>Centralized auth,<br>distributed verification.</h1>
      <p class="lede">
        Production-grade authentication microservice issuing RS256 JWT tokens.
        Verify identities locally across any subsystem using our public JWKS endpoint.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="#endpoints">API Reference</a>
        <a class="btn btn-ghost" href="#integration">Integration Guides</a>
      </div>
      <div class="hero-meta">
        <div><strong>Algorithm</strong>RS256 / 2048-bit</div>
        <div><strong>Discovery</strong>/.well-known/jwks.json</div>
        <div><strong>Issuer</strong><%= issuer %></div>
        <div><strong>Status</strong>Operational</div>
      </div>
    </div>
  </section>

  <main class="container">
    <!-- Overview -->
    <section id="overview" class="section">
      <h2>Overview</h2>
      <p class="muted">The auth service manages user identity, credentials, and token issuance. Downstream systems validate tokens locally — no round-trips to the auth service on every request.</p>
      <div class="grid">
        <div class="card">
          <h3>🔐 Asymmetric Trust</h3>
          <p>RS256 keypairs enable any service to verify tokens without holding secrets. Rotate keys without redeploying clients.</p>
        </div>
        <div class="card">
          <h3>🔄 Refresh Token Rotation</h3>
          <p>Refresh tokens rotate on each use and revoke on password changes, providing secure session management.</p>
        </div>
        <div class="card">
          <h3>📡 JWKS Discovery</h3>
          <p>Public keys available at <code>/.well-known/jwks.json</code>. Subsystems cache and refresh as needed.</p>
        </div>
      </div>
    </section>

    <!-- API Endpoints -->
    <section id="endpoints" class="section">
      <h2>API Reference</h2>
      <p class="muted">Base URL: <code><%= baseUrl %></code>. All requests and responses use JSON. Errors follow <code>{ "error": { "code", "message" } }</code>.</p>

      <!-- Public Endpoints -->
      <h3 class="group-title">Public Endpoints</h3>
      
      <div class="endpoint">
        <div class="endpoint-header"><span class="method post">POST</span><span class="path">/api/auth/register</span></div>
        <div class="endpoint-body">
          <p>Create a new user account. A verification email is sent if email verification is enabled.</p>
          <table class="param-table"><thead><tr><th>Parameter</th><th>Type</th><th>Description</th></tr></thead><tbody>
            <tr><td><code>email</code></td><td>string</td><td>Valid email address (unique)</td></tr>
            <tr><td><code>password</code></td><td>string</td><td>Minimum 8 chars, 1 uppercase, 1 number, 1 special</td></tr>
            <tr><td><code>full_name</code></td><td>string</td><td>Display name</td></tr>
          </tbody></table>
          <pre><code>// Response 201 Created
{
  "user": { "id": "uuid", "email": "user@example.com", "full_name": "Jane Doe", "is_email_verified": false },
  "message": "Verification email sent"
}</code></pre>
        </div>
      </div>

      <div class="endpoint">
        <div class="endpoint-header"><span class="method post">POST</span><span class="path">/api/auth/login</span></div>
        <div class="endpoint-body">
          <p>Authenticate and receive access + refresh tokens. Access token expires in 15 minutes.</p>
          <table class="param-table"><tbody><tr><td><code>email</code></td><td>string</td></tr><tr><td><code>password</code></td><td>string</td></tr></tbody></table>
          <pre><code>// Response 200 OK
{
  "access_token": "eyJhbGc...",
  "refresh_token": "d4f8g...",
  "token_type": "Bearer",
  "expires_in": 900,
  "user": { "id": "...", "email": "...", "full_name": "..." }
}</code></pre>
        </div>
      </div>

      <div class="endpoint">
        <div class="endpoint-header"><span class="method post">POST</span><span class="path">/api/auth/refresh</span></div>
        <div class="endpoint-body">
          <p>Rotate refresh token and obtain a new access token pair.</p>
          <table class="param-table"><tbody><tr><td><code>refresh_token</code></td><td>string</td></tr></tbody></table>
        </div>
      </div>

      <div class="endpoint">
        <div class="endpoint-header"><span class="method post">POST</span><span class="path">/api/auth/forgot-password</span></div>
        <div class="endpoint-body"><p>Sends a password reset email. Always returns 200 to prevent user enumeration.</p></div>
      </div>

      <div class="endpoint">
        <div class="endpoint-header"><span class="method get">GET</span><span class="path">/.well-known/jwks.json</span></div>
        <div class="endpoint-body"><p>Public RSA keys in JWKS format for token verification.</p></div>
      </div>

      <h3 class="group-title">Authenticated Endpoints</h3>
      <p class="muted small">Include header: <code>Authorization: Bearer &lt;access_token&gt;</code></p>

      <div class="endpoint">
        <div class="endpoint-header"><span class="method get">GET</span><span class="path">/api/auth/me</span></div>
        <div class="endpoint-body"><p>Returns the authenticated user's profile.</p></div>
      </div>

      <div class="endpoint">
        <div class="endpoint-header"><span class="method put">PUT</span><span class="path">/api/auth/me</span></div>
        <div class="endpoint-body"><p>Update user profile (full_name).</p></div>
      </div>

      <div class="endpoint">
        <div class="endpoint-header"><span class="method post">POST</span><span class="path">/api/auth/change-password</span></div>
        <div class="endpoint-body"><p>Change password. Revokes all existing refresh tokens.</p></div>
      </div>

      <div class="endpoint">
        <div class="endpoint-header"><span class="method post">POST</span><span class="path">/api/auth/logout</span></div>
        <div class="endpoint-body"><p>Blacklists the current access token and invalidates refresh token family.</p></div>
      </div>

      <h3 class="group-title">Administrative Endpoints</h3>
      <p class="muted small">Include header: <code>X-Admin-Api-Key: &lt;key&gt;</code></p>
      <div class="endpoint"><div class="endpoint-header"><span class="method get">GET</span><span class="path">/admin/users</span></div></div>
      <div class="endpoint"><div class="endpoint-header"><span class="method delete">DELETE</span><span class="path">/admin/users/:id</span></div></div>
    </section>

    <!-- Integration Section - Professional multi-language samples -->
    <section id="integration" class="section">
      <h2>Integration Guides</h2>
      <p class="muted">Verify access tokens locally in your service. Cache the JWKS response and refresh on unknown <code>kid</code>.</p>

      <div class="tabs" id="languageTabs">
        <button class="tab active" data-lang="node">Node.js</button>
        <button class="tab" data-lang="python">Python</button>
        <button class="tab" data-lang="go">Go</button>
        <button class="tab" data-lang="java">Java</button>
        <button class="tab" data-lang="csharp">C#</button>
        <button class="tab" data-lang="php">PHP</button>
      </div>

      <!-- Node.js -->
      <div class="tab-panel active" data-panel="node">
        <pre><code>const jwt = require('jsonwebtoken');
const jwksClient = require('jwks-rsa');

const client = jwksClient({
  jwksUri: '<%= baseUrl %>/.well-known/jwks.json',
  cache: true,
  cacheMaxAge: 600000 // 10 minutes
});

function verifyToken(token) {
  return new Promise((resolve, reject) => {
    function getKey(header, callback) {
      client.getSigningKey(header.kid, (err, key) => {
        if (err) return callback(err);
        callback(null, key.getPublicKey());
      });
    }
    
    jwt.verify(token, getKey, {
      algorithms: ['RS256'],
      issuer: '<%= issuer %>'
    }, (err, decoded) => {
      err ? reject(err) : resolve(decoded);
    });
  });
}

// Express middleware example
app.use(async (req, res, next) => {
  const auth = req.headers.authorization;
  if (!auth?.startsWith('Bearer ')) {
    return res.status(401).json({ error: 'Missing token' });
  }
  try {
    req.user = await verifyToken(auth.split(' ')[1]);
    next();
  } catch {
    res.status(401).json({ error: 'Invalid token' });
  }
});</code></pre>
      </div>

      <!-- Python -->
      <div class="tab-panel" data-panel="python">
        <pre><code>import jwt
from jwt import PyJWKClient
from functools import wraps
from flask import request, jsonify

JWKS_URL = '<%= baseUrl %>/.well-known/jwks.json'
jwks_client = PyJWKClient(JWKS_URL, cache_keys=True)

def verify_token(token: str) -> dict:
    signing_key = jwks_client.get_signing_key_from_jwt(token).key
    return jwt.decode(
        token,
        signing_key,
        algorithms=['RS256'],
        issuer='<%= issuer %>',
        options={'require': ['exp', 'iat', 'sub']}
    )

def require_auth(f):
    @wraps(f)
    def decorated(*args, **kwargs):
        auth_header = request.headers.get('Authorization')
        if not auth_header or not auth_header.startswith('Bearer '):
            return jsonify({'error': 'Authorization required'}), 401
        token = auth_header.split(' ')[1]
        try:
            request.user = verify_token(token)
        except jwt.InvalidTokenError as e:
            return jsonify({'error': str(e)}), 401
        return f(*args, **kwargs)
    return decorated

# Usage
@app.route('/api/protected')
@require_auth
def protected():
    return jsonify({'user': request.user})</code></pre>
