      <!-- PHP -->
      <div class="tab-panel" data-panel="php">
        <pre><code>&lt;?php
use Firebase\JWT\JWT;
use Firebase\JWT\JWK;
use Firebase\JWT\Key;

function verifyToken($token) {
    $jwksUrl = '<%= baseUrl %>/.well-known/jwks.json';
    $jwksJson = file_get_contents($jwksUrl);
    $jwks = json_decode($jwksJson, true);
    
    $headers = JWT::headers($token);
    $kid = $headers['kid'];
    
    $keySet = JWK::parseKeySet($jwks);
    $key = $keySet[$kid];
    
    return JWT::decode($token, $key, ['RS256']);
}

// Middleware example
$headers = getallheaders();
if (!isset($headers['Authorization']) || !preg_match('/Bearer\s+(.*)$/', $headers['Authorization'], $matches)) {
    http_response_code(401);
    echo json_encode(['error' => 'Unauthorized']);
    exit;
}

try {
    $user = verifyToken($matches[1]);
    // Token is valid, proceed with request
} catch (Exception $e) {
    http_response_code(401);
    echo json_encode(['error' => $e->getMessage()]);
    exit;
}
?&gt;</code></pre>
      </div>

      <h3>Token Payload Structure</h3>
      <pre><code>{
  "sub": "42",              // User ID
  "email": "user@example.com",
  "name": "Jane Doe",
  "iat": 1714000000,        // Issued at (Unix timestamp)
  "exp": 1714000900,        // Expiration (15 minutes)
  "iss": "<%= issuer %>",
  "jti": "8b1a9953-c761-4e78-9c1c-..."  // Unique token ID
}</code></pre>
      
      <div class="note">
        <strong>🔐 Best Practices:</strong>
        <ul style="margin-top: 0.5rem; margin-left: 1.5rem;">
          <li>Cache JWKS response for 10–60 minutes; refresh only on unknown <code>kid</code></li>
          <li>Always validate <code>iss</code> and <code>exp</code> claims</li>
          <li>Never call the auth service on each request — verification is cryptographic and local</li>
          <li>Use refresh tokens for obtaining new access tokens without re-authentication</li>
        </ul>
      </div>
    </section>

    <!-- Security -->
    <section id="security" class="section">
      <h2>Security Model</h2>
      <div class="grid">
        <div class="card"><h3>Password Storage</h3><p>Bcrypt cost factor 12. Password changes revoke all refresh tokens.</p></div>
        <div class="card"><h3>Token Revocation</h3><p>Logout blacklists access token JTI. Refresh tokens rotate on each use.</p></div>
        <div class="card"><h3>Rate Limiting</h3><p>Auth routes: 50 requests per 15 minutes per IP.</p></div>
        <div class="card"><h3>Headers & TLS</h3><p>Helmet security headers. Terminate TLS at your edge.</p></div>
      </div>
    </section>
