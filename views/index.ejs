      <!-- Java -->
      <div class="tab-panel" data-panel="java">
        <pre><code>import com.nimbusds.jose.JWSVerifier;
import com.nimbusds.jose.crypto.RSASSAVerifier;
import com.nimbusds.jose.jwk.JWKSet;
import com.nimbusds.jose.jwk.RSAKey;
import com.nimbusds.jwt.SignedJWT;
import java.net.URL;
import java.util.concurrent.TimeUnit;

public class TokenVerifier {
    private static JWKSet jwks;
    private static long lastFetch = 0;
    
    private static void refreshJWKS() throws Exception {
        if (System.currentTimeMillis() - lastFetch > TimeUnit.MINUTES.toMillis(10)) {
            jwks = JWKSet.load(new URL("<%= baseUrl %>/.well-known/jwks.json"));
            lastFetch = System.currentTimeMillis();
        }
    }
    
    public static SignedJWT verify(String token) throws Exception {
        refreshJWKS();
        SignedJWT signedJWT = SignedJWT.parse(token);
        String kid = signedJWT.getHeader().getKeyID();
        RSAKey rsaKey = jwks.getKeyByKeyId(kid).toRSAKey();
        JWSVerifier verifier = new RSASSAVerifier(rsaKey);
        if (!signedJWT.verify(verifier)) {
            throw new SecurityException("Invalid signature");
        }
        // Verify issuer and expiration
        if (!"<%= issuer %>".equals(signedJWT.getJWTClaimsSet().getIssuer())) {
            throw new SecurityException("Invalid issuer");
        }
        return signedJWT;
    }
}</code></pre>
