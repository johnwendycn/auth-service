{
  "name": "auth-service",
  "version": "1.0.0",
  "description": "Centralized auth microservice (MSC pattern) - JWT RS256, MySQL, Express",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest --runInBand --detectOpenHandles",
